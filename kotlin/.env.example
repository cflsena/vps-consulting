# Application
APP_PORT=8080

# PostgreSQL
POSTGRES_DB=credits
POSTGRES_USER=credits
POSTGRES_PASSWORD=credits
POSTGRES_PORT=5432

# Spring datasource (used by the app container)
DB_URL=jdbc:postgresql://postgres:5432/credits
DB_USER=credits
DB_PASS=credits

# RabbitMQ
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
